# Copie para .env e preencha com valores reais (NÃO comite o .env)
NODE_ENV=development

# Origem do front-end autorizada no CORS
FRONTEND_URL=http://localhost:3000

# Banco de dados
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=<usuario_app>
DB_PASSWORD=<senha_app>
DB_DATABASE=life_manager
# Em provedores gerenciados (Vercel/Neon/Prisma) defina DB_SSL=true
DB_SSL=false

# IA (OpenAI) — a chave é segredo, nunca comitar. Crie em platform.openai.com.
OPENAI_API_KEY=<sua_chave_openai>
OPENAI_MODEL=gpt-4o-mini

# Autenticação (usuário único fixo por enquanto) — valores reais SÓ no .env.
# JWT_SECRET: gere uma string longa e aleatória (ex.: openssl rand -hex 32).
JWT_SECRET=<segredo_jwt_aleatorio>
JWT_EXPIRES_IN=7d
AUTH_USERNAME=<seu_usuario>
AUTH_PASSWORD=<sua_senha>