# Copie para .env e preencha com valores reais (NÃO comite o .env)
NODE_ENV=development

# Origem do front-end autorizada no CORS
FRONTEND_URL=http://localhost:3000

# Banco de dados
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=<usuario_app>
DB_PASSWORD=<senha_app>
DB_DATABASE=life_manager
# Em provedores gerenciados (Vercel/Neon/etc.) defina DB_SSL=true
DB_SSL=false
